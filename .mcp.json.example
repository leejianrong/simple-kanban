{
  "//": "Copy to .mcp.json (repo root) for Claude Code. See mcp/README.md.",
  "//token": "Since V8 (ADR 0013) /api/v1 is auth-required, and V10 (ADR 0015) removed the shared API_TOKENS bypass. Create a personal access token in the SPA (Tokens tab, V9) and put the kanban_pat_... secret in KANBAN_TOKEN. It acts as your user and is owner-gated. An empty/invalid token yields 401.",
  "//boards": "KANBAN_BOARD_ID sets the default board (an integer id) for calls that omit board_id — it is preset to 1 (the seeded default board) so a wired agent doesn't accidentally target the wrong board. Call list_boards to find your board id and change 1 to it. Leave it empty to fall back to the API default instead (list = all your boards, create = your earliest).",
  "//prod": "Set KANBAN_API_URL to https://simple-kanban-jian.fly.dev and KANBAN_TOKEN to your kanban_pat_... secret.",
  "mcpServers": {
    "kanban": {
      "command": "uv",
      "args": ["run", "--directory", "./mcp", "python", "-m", "kanban_mcp"],
      "env": {
        "KANBAN_API_URL": "http://localhost:8000",
        "KANBAN_TOKEN": "",
        "KANBAN_BOARD_ID": "1"
      }
    }
  }
}
